use anyhow::{Context, Result};
use clap::Parser;
use log::{debug, error, info, warn};
use serde::Deserialize;
use std::process::Stdio;
use std::sync::Arc;
use swayipc::async_std::Connection as SwayConnection;
use swayipc::{Event, EventType};
use tokio::process::{Child, Command};
use tokio::sync::Mutex;
use tokio::time::{sleep, Duration};
use zbus::Connection as DbusConnection;

/// Clammy - Clamshell mode daemon for Sway
#[derive(Parser, Debug)]
#[command(author, version, about, long_about = None)]
struct Args {
	/// Enable verbose logging
	#[arg(short, long)]
	verbose: bool,
}

/// Minimal struct for parsing Sway output info
#[derive(Debug, Deserialize)]
struct SwayOutput {
	name: String,
	active: bool,
	current_mode: Option<OutputMode>,
	scale: f64,
}

#[derive(Debug, Deserialize)]
struct OutputMode {
	width: i32,
	height: i32,
}

/// System state tracker
#[derive(Debug, Clone)]
struct State {
	lid_closed: bool,
	external_monitors: Vec<String>,
	edp_name: Option<String>,
}

impl State {
	fn new() -> Self {
		Self {
			lid_closed: false,
			external_monitors: Vec::new(),
			edp_name: None,
		}
	}

	fn has_externals(&self) -> bool {
		!self.external_monitors.is_empty()
	}
}

/// Swayidle process manager
struct SwayidleManager {
	child: Option<Child>,
}

impl SwayidleManager {
	fn new() -> Self {
		Self { child: None }
	}

	async fn start(&mut self) -> Result<()> {
		if self.child.is_some() {
			info!("Swayidle already running, skipping start");
			return Ok(());
		}

		info!("Starting swayidle...");

		let lock_cmd = r#"swaylock -f \
			--screenshots \
			--clock \
			--indicator \
			--indicator-radius 120 \
			--indicator-thickness 8 \
			--effect-blur 7x5 \
			--effect-vignette 0.5:0.5 \
			--ring-color e94560 \
			--key-hl-color 0f3460 \
			--line-color 00000000 \
			--inside-color 1a1a2e88 \
			--separator-color 00000000 \
			--grace 3 \
			--fade-in 0.1"#;

		let child = Command::new("swayidle")
			.arg("-w")
			.arg("timeout")
			.arg("300")
			.arg(format!("{} -f -c 000000", lock_cmd))
			.arg("timeout")
			.arg("600")
			.arg("swaymsg \"output * power off\"")
			.arg("resume")
			.arg("swaymsg \"output * power on\"")
			.arg("before-sleep")
			.arg(format!("{} -f -c 000000", lock_cmd))
			.stdout(Stdio::null())
			.stderr(Stdio::null())
			.spawn()
			.context("Failed to spawn swayidle")?;

		self.child = Some(child);
		debug!("Swayidle started successfully");
		Ok(())
	}

	async fn stop(&mut self) -> Result<()> {
		if let Some(mut child) = self.child.take() {
			info!("Stopping swayidle...");
			child.kill().await.context("Failed to kill swayidle")?;
			debug!("Swayidle stopped successfully");
		}
		Ok(())
	}
}

/// Execute swaymsg command
async fn run_swaymsg(args: &[&str]) -> Result<()> {
	debug!("Running: swaymsg {}", args.join(" "));

	let output = Command::new("swaymsg")
		.args(args)
		.output()
		.await
		.context("Failed to execute swaymsg")?;

	if !output.status.success() {
		let stderr = String::from_utf8_lossy(&output.stderr);
		warn!("swaymsg failed: {}", stderr);
	}

	Ok(())
}

/// Get current outputs from Sway
async fn get_outputs() -> Result<(Option<String>, Vec<String>)> {
	let mut connection = SwayConnection::new()
		.await
		.context("Failed to connect to Sway")?;

	let outputs_raw = connection
		.get_outputs()
		.await
		.context("Failed to get outputs")?;

	let outputs: Vec<SwayOutput> = outputs_raw
		.into_iter()
		.filter_map(|output| {
			let value = serde_json::to_value(output).ok()?;
			serde_json::from_value(value).ok()
		})
		.collect();

	let mut edp_name = None;
	let mut externals = Vec::new();

	for output in outputs {
		if output.name.starts_with("eDP") {
			edp_name = Some(output.name);
		} else if output.active {
			externals.push(output.name);
		}
	}

	externals.sort();
	Ok((edp_name, externals))
}

/// Configure monitors for clamshell mode (lid closed with externals)
async fn configure_clamshell(state: &State) -> Result<()> {
	info!("Configuring clamshell mode...");

	// Disable eDP
	if let Some(edp) = &state.edp_name {
		debug!("Disabling eDP: {}", edp);
		run_swaymsg(&["output", edp, "disable"]).await?;
	}

	// Arrange external monitors left-to-right
	let mut x_offset = 0;

	for monitor in &state.external_monitors {
		debug!("Positioning monitor {} at x={}", monitor, x_offset);
		run_swaymsg(&["output", monitor, "pos", &x_offset.to_string(), "0"]).await?;

		// Calculate next offset (would need mode info, for now use fixed spacing)
		// TODO: Get actual monitor width from Sway
		x_offset += 1920; // Placeholder, will get actual width
	}

	// Restart waybar
	debug!("Restarting waybar...");
	let _ = Command::new("pkill").arg("waybar").status().await;
	run_swaymsg(&["exec", "waybar"]).await?;

	info!("Clamshell mode configured");
	Ok(())
}

/// Configure monitors for lid open (eDP leftmost)
async fn configure_lid_open(state: &State) -> Result<()> {
	info!("Configuring lid open mode...");

	let mut x_offset = 0;

	// Enable and position eDP leftmost
	if let Some(edp) = &state.edp_name {
		debug!("Enabling eDP at x=0: {}", edp);
		run_swaymsg(&["output", edp, "enable"]).await?;
		run_swaymsg(&["output", edp, "pos", "0", "0"]).await?;
		x_offset += 1920; // TODO: Get actual eDP width
	}

	// Position external monitors after eDP
	for monitor in &state.external_monitors {
		debug!("Positioning monitor {} at x={}", monitor, x_offset);
		run_swaymsg(&["output", monitor, "pos", &x_offset.to_string(), "0"]).await?;
		x_offset += 1920; // TODO: Get actual monitor width
	}

	// Restart waybar
	debug!("Restarting waybar...");
	let _ = Command::new("pkill").arg("waybar").status().await;
	run_swaymsg(&["exec", "waybar"]).await?;

	info!("Lid open mode configured");
	Ok(())
}

/// Handle state change and take appropriate action
async fn handle_state_change(
	state: &State,
	swayidle: &Arc<Mutex<SwayidleManager>>,
) -> Result<()> {
	info!(
		"State: lid_closed={}, externals={}, edp={:?}",
		state.lid_closed,
		state.external_monitors.len(),
		state.edp_name
	);

	if state.lid_closed {
		// Lid is closed
		let mut swayidle = swayidle.lock().await;
		swayidle.stop().await?;

		if state.has_externals() {
			// Clamshell mode
			configure_clamshell(state).await?;
		} else {
			// No externals - suspend after delay
			info!("No external monitors, suspending in 3 seconds...");
			sleep(Duration::from_secs(3)).await;

			Command::new("systemctl")
				.arg("suspend")
				.status()
				.await
				.context("Failed to suspend")?;
		}
	} else {
		// Lid is open
		configure_lid_open(state).await?;

		// Start swayidle
		let mut swayidle = swayidle.lock().await;
		swayidle.start().await?;
	}

	Ok(())
}

/// Listen for logind PrepareForSleep signal
async fn listen_lid_events(
	state: Arc<Mutex<State>>,
	swayidle: Arc<Mutex<SwayidleManager>>,
) -> Result<()> {
	info!("Starting logind listener...");

	let connection = DbusConnection::system()
		.await
		.context("Failed to connect to system D-Bus")?;

	let proxy = zbus::Proxy::new(
		&connection,
		"org.freedesktop.login1",
		"/org/freedesktop/login1",
		"org.freedesktop.login1.Manager",
	)
	.await
	.context("Failed to create logind proxy")?;

	let mut stream = proxy
		.receive_signal("PrepareForSleep")
		.await
		.context("Failed to receive PrepareForSleep signal")?;

	while let Some(signal) = stream.next().await {
		let args = signal.args().context("Failed to get signal args")?;
		let entering_sleep: bool = args.get(0).context("Missing sleep argument")?;

		debug!("PrepareForSleep signal: entering={}", entering_sleep);

		let mut state = state.lock().await;
		state.lid_closed = entering_sleep;

		if let Err(e) = handle_state_change(&state, &swayidle).await {
			error!("Failed to handle lid event: {}", e);
		}
	}

	Ok(())
}

/// Listen for Sway output events
async fn listen_output_events(
	state: Arc<Mutex<State>>,
	swayidle: Arc<Mutex<SwayidleManager>>,
) -> Result<()> {
	info!("Starting Sway output listener...");

	let mut connection = SwayConnection::new()
		.await
		.context("Failed to connect to Sway")?;

	let mut events = connection
		.subscribe([EventType::Output])
		.await
		.context("Failed to subscribe to output events")?;

	while let Some(event) = events.next().await {
		if let Event::Output(_) = event.context("Failed to get event")? {
			debug!("Output change detected");

			// Refresh output list
			let (edp, externals) = get_outputs().await?;

			let mut state = state.lock().await;
			let old_externals = state.external_monitors.clone();

			state.edp_name = edp;
			state.external_monitors = externals.clone();

			// Only reconfigure if externals changed
			if old_externals != externals {
				info!("External monitors changed: {:?} -> {:?}", old_externals, externals);

				// If lid closed and all externals gone - suspend after delay
				if state.lid_closed && !state.has_externals() {
					info!("All externals disconnected while lid closed, suspending in 5 seconds...");
					drop(state); // Release lock before sleeping

					sleep(Duration::from_secs(5)).await;

					Command::new("systemctl")
						.arg("suspend")
						.status()
						.await
						.context("Failed to suspend")?;
				} else if state.lid_closed {
					// Reconfigure clamshell layout
					if let Err(e) = handle_state_change(&state, &swayidle).await {
						error!("Failed to handle output change: {}", e);
					}
				}
			}
		}
	}

	Ok(())
}

#[tokio::main]
async fn main() -> Result<()> {
	let args = Args::parse();

	// Initialize logger
	if args.verbose {
		env_logger::Builder::from_default_env()
			.filter_level(log::LevelFilter::Debug)
			.init();
	} else {
		env_logger::Builder::from_default_env()
			.filter_level(log::LevelFilter::Info)
			.init();
	}

	info!("Clammy daemon starting...");

	// Get initial state
	let (edp, externals) = get_outputs().await?;

	let state = Arc::new(Mutex::new(State {
		lid_closed: false, // Assume lid open on start
		external_monitors: externals,
		edp_name: edp,
	}));

	let swayidle = Arc::new(Mutex::new(SwayidleManager::new()));

	// Start swayidle initially (assuming lid open)
	{
		let mut swayidle_lock = swayidle.lock().await;
		swayidle_lock.start().await?;
	}

	info!("Clammy initialized, starting event listeners...");

	// Spawn event listeners
	let state_lid = state.clone();
	let swayidle_lid = swayidle.clone();
	let lid_task = tokio::spawn(async move {
		if let Err(e) = listen_lid_events(state_lid, swayidle_lid).await {
			error!("Lid event listener failed: {}", e);
		}
	});

	let state_output = state.clone();
	let swayidle_output = swayidle.clone();
	let output_task = tokio::spawn(async move {
		if let Err(e) = listen_output_events(state_output, swayidle_output).await {
			error!("Output event listener failed: {}", e);
		}
	});

	// Wait for both tasks
	tokio::try_join!(lid_task, output_task)?;

	Ok(())
}
