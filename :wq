/// A struct to hold relevant monitor info, including resolution
#[derive(Debug, Clone, PartialEq)]
pub struct Monitor {
    pub name: String,
    pub width: i32, // swayipc::Rect uses i32
    pub active: bool,
}

impl From<Output> for Monitor {
    fn from(output: Output) -> Self {
        Self {
            name: output.name,
            width: output.rect.width,
            active: output.active,
        }
    }
}

/// Execute swaymsg command
pub fn run_swaymsg(args: &[&str]) -> Result<()> {
    debug!("Running: swaymsg {}", args.join(" "));

    let output = Command::new("swaymsg")
        .args(args)
        .output()
        .context("Failed to execute swaymsg")?;

    if !output.status.success() {
        let stderr = String::from_utf8_lossy(&output.stderr);
        warn!("swaymsg failed: {}", stderr);
    }

    Ok(())
}

/// Get current outputs from Sway, now returning Monitor structs
pub fn get_outputs() -> Result<(Option<Monitor>, Vec<Monitor>)> {
    debug!("Getting outputs from Sway...");
    let mut connection = Connection::new().context("Failed to connect to Sway")?;

    let outputs = connection
        .get_outputs()
        .context("Failed to get outputs")?;

    let mut edp_monitor = None;
    let mut externals = Vec::new();

    for output in outputs {
        let monitor = Monitor::from(output); // Convert to our struct
        if monitor.name.starts_with("eDP") {
            debug!("Found eDP: {:?}", monitor);
            edp_monitor = Some(monitor);
        } else if monitor.active {
            debug!("Found active external monitor: {:?}", monitor);
            externals.push(monitor);
        }
    }

    externals.sort_by(|a, b| a.name.cmp(&b.name)); // Sort by name
    debug!("Outputs found: eDP={:?}, externals={:?}", edp_monitor, externals);
    Ok((edp_monitor, externals))
}

pub fn lock_screen() -> Result<()> {
    info!("Telling Sway to execute $lock command...");
    run_swaymsg(&["exec", "$lock"])
}

/// Turn displays off using DPMS
pub fn displays_off() -> Result<()> {
    info!("Turning displays off (DPMS)...");
    run_swaymsg(&["output", "*", "power", "off"])
}

/// Turn displays on using DPMS
pub fn displays_on() -> Result<()> {
    info!("Turning displays on (DPMS)...");
    run_swaymsg(&["output", "*", "power", "on"])
}

/// Configure monitors for clamshell mode (lid closed with externals)
/// Uses actual monitor width instead of hardcoded 1920
pub fn configure_clamshell(state: &State) -> Result<()> {
    info!("Configuring clamshell mode...");

    // Disable eDP
    if let Some(edp) = &state.edp_name {
        debug!("Disabling eDP: {}", edp.name);
        run_swaymsg(&["output", &edp.name, "disable"])?;
    }

    // Arrange external monitors left-to-right
    let mut x_offset: i64 = 0; // Use i64 for offset
    for monitor in &state.external_monitors {
        debug!("Enabling and positioning monitor {} (width={}) at x={}", monitor.name, monitor.width, x_offset);
        // Ensure monitor is enabled before positioning
        run_swaymsg(&["output", &monitor.name, "enable"])?;
        run_swaymsg(&["output", &monitor.name, "pos", &x_offset.to_string(), "0"])?;
        
        // Use the *actual* monitor width for the next offset
        x_offset += monitor.width as i64; 
    }

    info!("Clamshell mode configured");
    Ok(())
}

/// Configure monitors for lid open (eDP leftmost)
/// Uses actual monitor width instead of hardcoded 1920
pub fn configure_lid_open(state: &State) -> Result<()> {
    info!("Configuring lid open mode...");

    let mut x_offset: i64 = 0; // Use i64 for offset

    // Enable and position eDP leftmost
    if let Some(edp) = &state.edp_name {
        debug!("Enabling and positioning eDP {} (width={}) at x=0", edp.name, edp.width);
        run_swaymsg(&["output", &edp.name, "enable"])?;
        run_swaymsg(&["output", &edp.name, "pos", "0", "0"])?;
        
        // Use the *actual* eDP width for the next offset
        x_offset += edp.width as i64;
    }

    // Position external monitors after eDP
    for monitor in &state.external_monitors {
        debug!("Enabling and positioning monitor {} (width={}) at x={}", monitor.name, monitor.width, x_offset);
        run_swaymsg(&["output", &monitor.name, "enable"])?;
        run_swaymsg(&["output", &monitor.name, "pos", &x_offset.to_string(), "0"])?;
        
        // Use the *actual* monitor width for the next offset
        x_offset += monitor.width as i64; 
    }

    info!("Lid open mode configured");
    Ok(())
}


/// Handle lid close
pub fn handle_lid_close(state: &mut State) -> Result<()> {
    info!("Lid closed");
    state.lid_closed = true;

    lock_screen()?;

    // Turn displays off if they aren't already
    if !state.displays_off {
        debug!("Displays were on, turning off for lid close");
        if let Err(e) = displays_off() {
             warn!("Failed to turn displays off on lid close: {}", e);
        }
        state.displays_off = true;
    } else {
        debug!("Displays already off, no action needed.");
    }

//    // Configure displays
//    if state.has_externals() {
//        debug!("Lid closed with external monitors, configuring clamshell...");
//        configure_clamshell(state)?;
//    } else {
//        debug!("Lid closed with no external monitors.");
//    }

    Ok(())
}

/// Handle lid open
pub fn handle_lid_open(state: &mut State) -> Result<()> {
    info!("Lid opened");
    state.lid_closed = false;

    // Only turn displays on if they were off
    if state.displays_off {
        debug!("Displays were off, turning on for lid open");
        displays_on()?;
        state.displays_off = false;
    } else {
         debug!("Displays already on, no action needed.");
    }
    
    debug!("Configuring for lid open mode...");
    configure_lid_open(state)?;
    Ok(())
}

/// Listens for Sway output events (monitor plug/unplug) in a blocking thread
pub fn listen_sway_events(state: SharedState) -> Result<()> {
    info!("Starting Sway event listener...");

    loop {
        let connection = match Connection::new() {
            Ok(c) => c,
            Err(e) => {
                error!("Failed to connect to Sway: {}", e);
                thread::sleep(Duration::from_secs(5));
                continue;
            }
        };
        debug!("Sway event listener connected");

        let events = match connection.subscribe([EventType::Output]) {
            Ok(e) => e,
            Err(e) => {
                error!("Failed to subscribe to events: {}", e);
                thread::sleep(Duration::from_secs(5));
                continue;
            }
        };
        debug!("Sway event listener subscribed to Output events");

        for event in events {
            let event = match event {
                Ok(e) => e,
                Err(e) => {
                    warn!("Event error: {}, reconnecting...", e);
                    break;
                }
            };

            if let Event::Output(_) = event {
                debug!("Sway output change detected");
                let mut state = state.lock().unwrap();
                debug!("State lock acquired for output event");

                // Get a snapshot of the state *before* refreshing
                let old_state = state.clone();

                // Refresh monitor list
                if let Err(e) = state.refresh_outputs() {
                    error!("Failed to refresh outputs after event: {}", e);
                    debug!("State lock released after output event error");
                    drop(state); // Explicitly drop lock
                    continue;
                }

                // Check if anything actually changed
                if old_state.external_monitors == state.external_monitors && old_state.edp_name == state.edp_name {
                    debug!("Output event detected, but no change in active monitors. Ignoring.");
                    debug!("State lock released for output event (no change)");
                    drop(state); // Explicitly drop lock
                    continue; 
                }
                
                info!("External monitors changed: {:?} -> {:?}", old_state.external_monitors, state.external_monitors);

                // If lid is closed, re-apply clamshell mode
                if state.lid_closed {
                    debug!("Lid is closed, re-applying display logic for hotplug...");
                    if state.has_externals() {
                        debug!("Configuring clamshell for new monitors...");
                        if let Err(e) = configure_clamshell(&state) {
                            error!("Failed to configure clamshell: {}", e);
                        }
                    } else {
                        info!("No externals while lid closed, re-enabling eDP");
                        if let Some(edp) = &state.edp_name {
                            if let Err(e) = run_swaymsg(&["output", &edp.name, "enable"]) {
                                error!("Failed to enable eDP: {}", e);
                            }
                        }
                    }
                } else {
                    // Lid is open, apply lid open config
                    debug!("Lid is open, re-configuring for new monitors...");
                     if let Err(e) = configure_lid_open(&state) {
                        error!("Failed to configure lid open: {}", e);
                    }
                }
                debug!("State lock released for output event");
            }
        }

        warn!("Sway event stream ended, reconnecting in 5 seconds...");
        thread::sleep(Duration::from_secs(5));
    }
}
